## 환경변수 예시 파일(.env.example)
## - 실제 비밀값은 넣지 말고 형식만 공유합니다.
## - 로컬에서는 이 파일을 복사해 .env를 만들어 사용하세요.

DATABASE_URL=postgresql://user:password@localhost:5432/picklog

SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Kakao OAuth (모바일 SDK access_token 검증용)
# 향후 토큰 검증 강화 시 활용 (현재 미사용 — REST API Key)
KAKAO_REST_API_KEY=your-kakao-rest-api-key

